<view class="container cat-container">
  <!-- 顶部搜索 -->
  <view class="top-bar">
    <view class="search-box" bindtap="goSearch">
      <view class="search-icon">搜</view>
      <view class="search-placeholder">搜索陶瓷品名 / 货号</view>
    </view>
  </view>

  <view class="cat-body">
    <!-- 左侧一级分类 -->
    <scroll-view class="cat-left" scroll-y="{{true}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="cat-l-item {{activeCat === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCatTap"
      >{{item.name}}</view>
    </scroll-view>

    <!-- 右侧内容 -->
    <scroll-view class="cat-right" scroll-y="{{true}}">
      <!-- Banner -->
      <view class="cat-banner">
        <view class="cat-banner-title">{{activeCatName}}</view>
        <view class="cat-banner-sub">严选产区 · 厂家直发 · 48h 内发货</view>
      </view>

      <!-- 子分类宫格 -->
      <view class="cat-grid">
        <view
          wx:for="{{subCats}}"
          wx:key="name"
          class="cat-grid-item"
          data-name="{{item.name}}"
          bindtap="onSubCatTap"
        >
          <view class="cat-grid-icon">{{item.icon}}</view>
          <text class="cat-grid-name">{{item.name}}</text>
        </view>
      </view>

      <!-- 推荐商品 -->
      <view class="section-title">热销推荐</view>
      <view class="rec-list">
        <view
          wx:for="{{recList}}"
          wx:key="id"
          class="rec-item"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image src="{{item.image}}" mode="aspectFill" class="rec-img" />
          <view class="rec-name ellipsis-2">{{item.name}}</view>
          <view class="rec-price">¥{{item.price}}<text class="rec-unit">/{{item.unit}} 起</text></view>
          <view class="rec-moq">≥{{item.minOrderQty}} {{item.unit}} 起批</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
