<view class="container cat-container">
  <!-- 顶部搜索 -->
  <view class="top-bar">
    <view class="search-box" bindtap="goSearch">
      <view class="search-icon">搜</view>
      <view class="search-placeholder">搜索陶瓷品名 / 货号</view>
    </view>
  </view>

  <view class="cat-body">
    <!-- 左侧一级分类 -->
    <scroll-view class="cat-left" scroll-y="{{true}}">
      <view
        wx:for="{{tree}}"
        wx:key="id"
        wx:if="{{!item.parentId}}"
        class="cat-l-item {{activeCat === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCatTap"
      >{{item.name}}</view>
      <view wx:if="{{tree.length === 0 && !loading}}" class="cat-l-empty">暂无分类</view>
    </scroll-view>

    <!-- 右侧内容 -->
    <scroll-view class="cat-right" scroll-y="{{true}}">
      <view class="cat-banner">
        <view class="cat-banner-title">{{activeCatName || '请选择分类'}}</view>
        <view class="cat-banner-sub">严选产区 · 厂家直发 · 48h 内发货</view>
      </view>

      <!-- 子分类宫格 -->
      <view class="cat-grid" wx:if="{{subCats.length > 0}}">
        <view
          wx:for="{{subCats}}"
          wx:key="id"
          class="cat-grid-item"
          data-id="{{item.id}}"
          bindtap="onSubCatTap"
        >
          <view class="cat-grid-icon">{{item.icon}}</view>
          <text class="cat-grid-name ellipsis-2">{{item.name}}</text>
        </view>
      </view>

      <!-- 推荐商品 -->
      <view class="section-title">热销推荐</view>
      <view wx:if="{{recList.length === 0}}" class="rec-empty">暂无推荐商品</view>
      <view class="rec-list">
        <view
          wx:for="{{recList}}"
          wx:key="id"
          class="rec-item"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="rec-img" />
          <view wx:else class="rec-img rec-img-empty">暂无图</view>
          <view class="rec-name ellipsis-2">{{item.name}}</view>
          <view class="rec-price">¥{{item.price}}</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
