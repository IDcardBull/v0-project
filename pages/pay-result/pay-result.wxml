<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{polling}}" class="result">
    <view class="result-icon loading">·</view>
    <view class="result-title">支付结果确认中</view>
    <view class="result-sub">正在从微信支付平台同步状态…</view>
  </view>

  <!-- 已确认支付成功 -->
  <view wx:elif="{{order && (fakePay || order.status === 'pending_ship' || order.status === 'paid' || order.status === 'shipped' || order.status === 'completed')}}" class="result">
    <view class="result-icon success">✓</view>
    <view class="result-title">支付成功</view>
    <view class="result-sub">{{fakePay ? '当前为假支付，仅用于流程验证' : '订单号 ' + order.orderNo}}</view>
    <view class="amount">¥{{order.paidAmount || order.totalAmount}}</view>

    <view class="actions">
      <view class="btn btn-outline" bindtap="goOrderDetail">查看订单</view>
      <view class="btn btn-primary" bindtap="goHome">继续选购</view>
    </view>
  </view>

  <!-- 用户取消或还未到账 -->
  <view wx:elif="{{order && order.status === 'pending_pay'}}" class="result">
    <view class="result-icon warn">!</view>
    <view class="result-title">{{initialStatus === 'cancel' ? '已取消支付' : '支付未完成'}}</view>
    <view class="result-sub">订单号 {{order.orderNo}}</view>
    <view class="amount muted">应付 ¥{{order.totalAmount}}</view>

    <view class="actions">
      <view class="btn btn-outline" bindtap="goHome">继续选购</view>
      <view class="btn btn-primary" bindtap="retryPay">继续支付</view>
    </view>
  </view>

  <!-- 已关闭 / 异常 -->
  <view wx:else class="result">
    <view class="result-icon warn">!</view>
    <view class="result-title">订单状态异常</view>
    <view class="result-sub" wx:if="{{order}}">订单号 {{order.orderNo}} · {{order.status}}</view>
    <view class="actions">
      <view class="btn btn-primary" bindtap="goOrderDetail">查看订单详情</view>
    </view>
  </view>
</view>
