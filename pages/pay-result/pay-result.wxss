.container {
  min-height: 100vh;
  background: #fff;
}

.result {
  padding: 120rpx 60rpx 0;
  text-align: center;
}

.result-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  font-weight: 700;
  color: #fff;
}
.result-icon.success {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}
.result-icon.warn {
  background: linear-gradient(135deg, #f5a623, #ec8b00);
  box-shadow: 0 8rpx 24rpx rgba(245, 166, 35, 0.3);
}
.result-icon.loading {
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 80rpx;
  animation: pulse 1.2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.6; }
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}
.result-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
}
.amount {
  margin-top: 32rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--price);
}
.amount.muted { color: var(--text); }

.actions {
  margin-top: 80rpx;
  display: flex;
  gap: 16rpx;
  justify-content: center;
}
.actions .btn {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
