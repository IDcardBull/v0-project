<view class="page">
  <view class="brand">
    <view class="brand-logo">央茗</view>
    <view class="brand-title">央茗陶瓷 · 批发商城</view>
    <view class="brand-sub">景德镇源头工厂 · B2B 批发专享</view>
  </view>

  <view class="form">
    <view class="field">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="field">
      <text class="label">验证码</text>
      <view class="code-row">
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="请输入短信验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="code-btn {{counting ? 'counting' : ''}}"
          size="mini"
          disabled="{{counting}}"
          bindtap="sendCode"
        >
          {{counting ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>

    <button class="submit {{loading ? 'loading' : ''}}" disabled="{{loading}}" bindtap="onPhoneLogin">
      {{loading ? '登录中...' : '登 录 / 注 册'}}
    </button>

    <view class="agree">
      <text class="checkbox {{agree ? 'checked' : ''}}" bindtap="toggleAgree"></text>
      <text class="agree-text">登录即同意</text>
      <text class="link">《用户协议》</text>
      <text class="agree-text">与</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>

  <view class="other">
    <view class="divider"><text>其他登录方式</text></view>
    <view class="wx-login" bindtap="onWxLogin">
      <text class="wx-icon">微信</text>
      <text>微信一键登录</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">如需批发分级价，登录后请完善企业资质</text>
  </view>
</view>
