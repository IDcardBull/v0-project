<view class="page">
  <view class="brand">
    <image class="brand-logo" src="/images/logo.png" mode="aspectFit"></image>
    <view class="brand-title">央皿陶瓷 · 批发商城</view>
    <view class="brand-sub">景德镇源头工厂 · B2B 批发专享</view>
  </view>

  <view class="form">
    <button class="submit {{loading ? 'loading' : ''}}" disabled="{{loading}}" bindtap="onWxLogin">
      {{loading ? '登 录 中 ...' : '一 键 登 录'}}
    </button>

    <view class="agree">
      <text class="checkbox {{agree ? 'checked' : ''}}" bindtap="toggleAgree"></text>
      <text class="agree-text">登录即同意</text>
      <text class="link" catchtap="showAgreement">《用户协议》</text>
      <text class="agree-text">与</text>
      <text class="link" catchtap="showPrivacy">《隐私政策》</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">如需批发分级价，登录后请完善企业资质</text>
  </view>
</view>
