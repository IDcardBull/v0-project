<view class="container">
  <view class="form">
    <view class="row">
      <text class="label">收货人</text>
      <input
        class="input"
        placeholder="姓名"
        value="{{form.receiver}}"
        data-key="receiver"
        bindinput="onInput"
        maxlength="20"
      />
    </view>

    <view class="row">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="11 位手机号"
        value="{{form.phone}}"
        data-key="phone"
        bindinput="onInput"
      />
    </view>

    <view class="row">
      <text class="label">所在地区</text>
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <view class="picker-value {{!form.province ? 'placeholder' : ''}}">
          {{form.province ? form.province + ' ' + form.city + ' ' + form.district : '请选择（需下拉选择）'}}
        </view>
      </picker>
    </view>

    <view class="row row-block">
      <text class="label">详细地址</text>
      <textarea
        class="textarea"
        placeholder="街道、楼栋、门牌号"
        value="{{form.detail}}"
        data-key="detail"
        bindinput="onInput"
        maxlength="200"
        auto-height
      />
    </view>

    <view class="row">
      <text class="label">标签</text>
      <view class="tag-list">
        <view
          wx:for="{{['家', '公司', '学校']}}"
          wx:key="*this"
          class="tag-item {{form.tag === item ? 'active' : ''}}"
          data-tag="{{item}}"
          bindtap="setTag"
        >{{item}}</view>
      </view>
    </view>

    <view class="row" bindtap="toggleDefault">
      <text class="label">设为默认</text>
      <view class="switch {{form.isDefault ? 'on' : ''}}">
        <view class="switch-dot"></view>
      </view>
    </view>
  </view>

  <view class="bar">
    <view class="save-btn {{submitting ? 'disabled' : ''}}" bindtap="save">
      {{submitting ? '保存中...' : '保 存'}}
    </view>
  </view>
</view>
