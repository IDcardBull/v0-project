.container {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 200rpx;
}

.form {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--divider);
  gap: 24rpx;
  min-height: 100rpx;
}
.row:last-child { border-bottom: none; }
.row-block {
  align-items: flex-start;
  padding: 24rpx 0;
}

.label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--text-2);
}

.input,
.picker-value,
.textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}
.picker-value.placeholder { color: var(--muted); }

.textarea {
  min-height: 140rpx;
  line-height: 1.5;
  width: 100%;
}

.tag-list {
  display: flex;
  gap: 12rpx;
}
.tag-item {
  padding: 8rpx 24rpx;
  border: 2rpx solid var(--divider);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-2);
  background: #fafafa;
}
.tag-item.active {
  border-color: var(--brand);
  color: var(--brand);
  background: var(--brand-soft);
}

.switch {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #e0e0e0;
  position: relative;
  transition: background 0.2s;
}
.switch.on { background: var(--brand); }
.switch-dot {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  transition: left 0.2s;
}
.switch.on .switch-dot { left: 40rpx; }

.bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--divider);
}
.save-btn {
  height: 88rpx;
  background: var(--brand);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn.disabled { opacity: 0.6; }
.save-btn:active { opacity: 0.85; }
