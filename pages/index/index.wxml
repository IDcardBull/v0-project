<view class="container">
  <!-- 搜索栏 -->
  <view class="top-bar">
    <view class="search-box" bindtap="goSearch">
      <view class="search-icon">搜</view>
      <view class="search-placeholder">搜索陶瓷品名 / 货号 / 厂家</view>
      <view class="search-scan">扫</view>
    </view>
  </view>

  <!-- 分类横滑 -->
  <scroll-view class="cat-nav" scroll-x="true" enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="cat-item {{activeCat === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onCatTap"
    >
      <text>{{item.name}}</text>
      <view class="cat-indicator" wx:if="{{activeCat === item.id}}"></view>
    </view>
  </scroll-view>

  <!-- 筛选条 -->
  <view class="filter-bar">
    <view
      wx:for="{{sortOptions}}"
      wx:key="id"
      class="filter-item {{sortBy === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onSortTap"
    >{{item.name}}</view>
    <view class="filter-spacer"></view>
    <view class="filter-right" bindtap="openFilter">筛选 ⌃</view>
  </view>

  <!-- 商品列表 -->
  <view class="list">
    <block wx:for="{{list}}" wx:key="id">
      <product-card
        product="{{item}}"
        qty="{{cartMap[item.id] || 0}}"
        bind:change="onQtyChange"
      />
    </block>

    <view wx:if="{{list.length === 0}}" class="empty">
      <view class="empty-title">暂无匹配商品</view>
      <view class="empty-sub">换个分类试试看</view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
