.container { padding-bottom: 40rpx; min-height: 100vh; background: #f5f5f7; }

.address-card {
  position: relative;
  background: #fff;
  margin: 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  border-left: 8rpx solid var(--brand);
}
.addr-line1 {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
}
.addr-name { font-size: 30rpx; font-weight: 700; }
.addr-phone { font-size: 26rpx; color: var(--text-2); font-weight: 400; }
.addr-default {
  font-size: 20rpx;
  background: var(--brand);
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 400;
}
.addr-line2 {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-2);
  line-height: 1.5;
  padding-right: 30rpx;
}
.addr-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #ccc;
  font-size: 40rpx;
}
.addr-empty {
  font-size: 28rpx;
  color: var(--muted);
}

.goods-card,
.remark-card,
.amount-card {
  background: #fff;
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}
.card-title {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.goods-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--divider);
}
.goods-item:last-child { border-bottom: none; padding-bottom: 0; }
.goods-img {
  width: 140rpx;
  height: 140rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.goods-img-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 22rpx;
}
.goods-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.goods-name {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.35;
}
.goods-spec {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
.goods-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.goods-price {
  font-size: 28rpx;
  color: var(--price);
  font-weight: 700;
}
.goods-qty {
  font-size: 24rpx;
  color: var(--muted);
}

.remark-input {
  width: 100%;
  font-size: 26rpx;
  color: var(--text);
  background: #fafafa;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  box-sizing: border-box;
  min-height: 60rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: var(--text-2);
}
.amount-row.total {
  font-weight: 700;
  font-size: 28rpx;
  color: var(--text);
}
.amount-divider {
  height: 2rpx;
  background: var(--divider);
  margin: 8rpx 0;
}
.amount-total {
  font-size: 36rpx;
  color: var(--price);
  font-weight: 700;
}

.bar-placeholder { height: 130rpx; }

.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--divider);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.bb-left {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-2);
}
.bb-price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--price);
}
.bb-submit {
  height: 84rpx;
  padding: 0 60rpx;
  background: linear-gradient(135deg, #e63946, #c1121f);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bb-submit.disabled { opacity: 0.6; }
.bb-submit:active { opacity: 0.85; }
