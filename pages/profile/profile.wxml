<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-head">
    <view class="user-avatar">{{userInfo ? userInfo.name.charAt(0) : '企'}}</view>
    <view class="user-info">
      <block wx:if="{{userInfo}}">
        <view class="user-name">{{userInfo.name}}</view>
        <view class="user-role">
          <text class="tag">{{userInfo.level}}</text>
          <text>{{userInfo.phone}}</text>
        </view>
      </block>
      <block wx:else>
        <view class="user-name">未登录</view>
        <view class="user-role">登录后享受会员批发价</view>
      </block>
    </view>
    <view class="user-action" bindtap="goLogin">{{userInfo ? '店铺认证' : '登录'}}</view>
  </view>

  <!-- 订单概览 -->
  <view class="order-panel card">
    <view class="panel-head">
      <text class="panel-title">我的订单</text>
      <view class="panel-more" bindtap="goOrders" data-status="all">全部订单 ›</view>
    </view>
    <view class="order-grid">
      <view class="order-cell" data-status="unpaid" bindtap="goOrders">
        <view class="order-num">{{stats.unpaid}}</view>
        <view class="order-label">待付款</view>
      </view>
      <view class="order-cell" data-status="paid" bindtap="goOrders">
        <view class="order-num">{{stats.paid}}</view>
        <view class="order-label">待发货</view>
      </view>
      <view class="order-cell" data-status="shipped" bindtap="goOrders">
        <view class="order-num">{{stats.shipped}}</view>
        <view class="order-label">已发货</view>
      </view>
      <view class="order-cell" data-status="done" bindtap="goOrders">
        <view class="order-num">{{stats.done}}</view>
        <view class="order-label">已完成</view>
      </view>
      <view class="order-cell" bindtap="callService">
        <view class="order-num">—</view>
        <view class="order-label">售后</view>
      </view>
    </view>
  </view>

  <!-- 会员信息面板 -->
  <view class="vip-card">
    <view class="vip-title">央茗金牌批发会员</view>
    <view class="vip-sub">累计采购 ¥68,800 · 再采购 ¥31,200 升级钻石会员</view>
    <view class="vip-progress"><view class="vip-bar" style="width: 68%"></view></view>
    <view class="vip-btn">查看会员权益</view>
  </view>

  <!-- 服务菜单 -->
  <view class="menu card">
    <view class="menu-title">常用服务</view>
    <view class="menu-row">
      <view class="menu-item" bindtap="goAddress">
        <view class="menu-icon">址</view>
        <text>收货地址</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">票</view>
        <text>发票抬头</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">证</view>
        <text>营业执照</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">约</view>
        <text>合作合约</text>
      </view>
      <view class="menu-item" bindtap="callService">
        <view class="menu-icon">客</view>
        <text>专属客服</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">厂</view>
        <text>工厂实拍</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">样</view>
        <text>样品申请</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon">询</view>
        <text>批量询价</text>
      </view>
    </view>
  </view>

  <!-- 列表菜单 -->
  <view class="list-menu card">
    <view class="list-row">
      <text>地址管理</text>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-row">
      <text>消息通知</text>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-row">
      <text>意见反馈</text>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-row">
      <text>关于央茗陶瓷</text>
      <text class="list-arrow">v1.0.0</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
