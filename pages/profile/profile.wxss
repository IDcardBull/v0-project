.user-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #3c5a6f 0%, #4a6d82 100%);
  color: #fff;
}
.user-avatar {
  width: 112rpx; height: 112rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  border: 2rpx solid rgba(255,255,255,.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.user-info { flex: 1; min-width: 0; }
.user-name { font-size: 34rpx; font-weight: 700; }
.user-role {
  font-size: 22rpx;
  opacity: .85;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.user-role .tag {
  background: rgba(255,255,255,.22);
  color: #fff;
}
.user-action {
  padding: 12rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,.65);
  border-radius: 30rpx;
  font-size: 24rpx;
}

.card {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.order-panel { padding: 24rpx; }
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
}
.panel-title { font-size: 28rpx; font-weight: 700; color: var(--text); }
.panel-more { font-size: 24rpx; color: var(--muted); }
.order-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}
.order-cell {
  text-align: center;
  padding: 16rpx 0;
}
.order-num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}
.order-label {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 2rpx;
}

.vip-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #2c3e50, #3c5a6f);
  color: #fff;
  padding: 28rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}
.vip-title {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}
.vip-sub {
  font-size: 22rpx;
  opacity: .8;
  margin-top: 8rpx;
}
.vip-progress {
  margin-top: 20rpx;
  height: 6rpx;
  background: rgba(255,255,255,.2);
  border-radius: 3rpx;
  overflow: hidden;
}
.vip-bar {
  height: 100%;
  background: #e2c97a;
  border-radius: 3rpx;
}
.vip-btn {
  margin-top: 20rpx;
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 22rpx;
  border: 2rpx solid rgba(255,255,255,.6);
  color: #fff;
  border-radius: 30rpx;
}

.menu { padding: 24rpx; }
.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}
.menu-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  font-size: 22rpx;
  color: var(--text-2);
}
.menu-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--brand-soft);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.list-menu { padding: 0 24rpx; }
.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  border-bottom: 2rpx solid var(--divider);
  font-size: 26rpx;
  color: var(--text);
}
.list-row:last-child { border-bottom: none; }
.list-arrow { color: var(--muted); font-size: 24rpx; }

.safe-bottom { height: 40rpx; }
