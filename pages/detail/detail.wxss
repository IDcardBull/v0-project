.d-loading {
  text-align: center;
  padding: 200rpx 0;
  color: var(--muted);
  font-size: 26rpx;
}

.d-swiper {
  width: 100%;
  height: 750rpx;
  background: #f5f5f5;
}
.d-swiper-img { width: 100%; height: 100%; }
.d-swiper-empty {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: #bbb; font-size: 28rpx;
}

.d-price-box {
  background: linear-gradient(135deg, #fdecea, #fff);
  padding: 24rpx;
  margin-top: -10rpx;
  border-radius: 16rpx 16rpx 0 0;
  position: relative;
  z-index: 2;
}
.d-price-main {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  color: var(--price);
}
.d-ccy { font-size: 28rpx; font-weight: 700; }
.d-price { font-size: 52rpx; font-weight: 700; line-height: 1; }
.d-unit { font-size: 22rpx; color: var(--muted); margin-left: 4rpx; }
.d-moq {
  margin-left: 20rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: var(--brand);
  background: var(--brand-soft);
  border-radius: 4rpx;
  font-weight: 400;
}
.d-price-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.d-title-card {
  background: #fff;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
}
.d-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text);
}
.d-attrs {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.d-sku {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.d-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}
.d-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--divider);
  margin-bottom: 16rpx;
}

/* SKU 规格选择 */
.d-spec-group {
  margin-bottom: 16rpx;
}
.d-spec-group:last-child { margin-bottom: 0; }
.d-spec-label {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 10rpx;
}
.d-spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.d-spec-opt {
  min-width: 96rpx;
  padding: 10rpx 24rpx;
  border: 2rpx solid var(--divider);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--text-2);
  text-align: center;
  background: #fafafa;
}
.d-spec-opt.active {
  border-color: var(--brand);
  color: var(--brand);
  background: var(--brand-soft);
  font-weight: 600;
}

/* 阶梯价 */
.d-tier-table {
  border: 2rpx solid var(--divider);
  border-radius: 8rpx;
  overflow: hidden;
}
.d-tier-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid var(--divider);
  font-size: 26rpx;
  color: var(--text-2);
}
.d-tier-row:last-child { border-bottom: none; }
.d-tier-row.active { background: #fdecea; }
.d-tier-row.active .d-tier-range { color: var(--price); font-weight: 600; }
.d-tier-price { color: var(--price); font-weight: 700; font-size: 30rpx; }
.d-tier-unit { font-size: 20rpx; font-weight: 400; color: var(--muted); margin-left: 4rpx; }

/* 数量 */
.d-qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.d-qty-tip {
  font-size: 22rpx;
  color: var(--muted);
}

/* 详情 */
.d-desc {
  font-size: 26rpx;
  color: var(--text-2);
  line-height: 1.65;
}
.d-desc-placeholder {
  color: var(--muted);
  font-size: 24rpx;
}

.bar-placeholder { height: 140rpx; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-top: 2rpx solid var(--divider);
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 10;
}
.bb-ic {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--text-2);
  padding: 0 6rpx;
  flex-shrink: 0;
}
.bb-ic-dot {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--brand-soft);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-bottom: 2rpx;
}
.bb-action {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}
.bb-cart {
  background: linear-gradient(135deg, #f5a623, #ec8b00);
  border-radius: 36rpx 0 0 36rpx;
}
.bb-buy {
  background: linear-gradient(135deg, #e63946, #c1121f);
  border-radius: 0 36rpx 36rpx 0;
}
.bb-action:active { opacity: .85; }
