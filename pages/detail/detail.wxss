.d-swiper {
  width: 100%;
  height: 750rpx;
  background: #f5f5f5;
}
.d-swiper-img { width: 100%; height: 100%; }

.d-price-box {
  background: linear-gradient(135deg, #fdecea, #fff);
  padding: 24rpx;
  margin-top: -10rpx;
  border-radius: 16rpx 16rpx 0 0;
  position: relative;
  z-index: 2;
}
.d-price-main {
  display: flex;
  align-items: baseline;
  color: var(--price);
}
.d-ccy { font-size: 28rpx; font-weight: 700; }
.d-price { font-size: 52rpx; font-weight: 700; line-height: 1; }
.d-unit { font-size: 22rpx; color: var(--muted); margin-left: 4rpx; }
.d-moq {
  margin-left: 20rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: var(--brand);
  background: var(--brand-soft);
  border-radius: 4rpx;
  font-weight: 400;
}
.d-price-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.d-title-card {
  background: #fff;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--divider);
}
.d-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text);
}
.d-attrs {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.d-sku {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.d-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}
.d-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--divider);
  margin-bottom: 16rpx;
}

.d-tier-table {
  border: 2rpx solid var(--divider);
  border-radius: 8rpx;
  overflow: hidden;
}
.d-tier-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid var(--divider);
  font-size: 26rpx;
  color: var(--text-2);
}
.d-tier-row:last-child { border-bottom: none; }
.d-tier-row.active { background: var(--price-soft); }
.d-tier-row.active .d-tier-range { color: var(--price); font-weight: 600; }
.d-tier-price { color: var(--price); font-weight: 700; font-size: 30rpx; }
.d-tier-unit { font-size: 20rpx; font-weight: 400; color: var(--muted); margin-left: 4rpx; }

.d-detail-row {
  display: flex;
  padding: 12rpx 0;
  font-size: 26rpx;
  border-bottom: 2rpx dashed #f0f0f0;
}
.d-detail-row:last-child { border-bottom: none; }
.d-detail-label {
  width: 140rpx;
  color: var(--muted);
  flex-shrink: 0;
}
.d-detail-value { color: var(--text); flex: 1; }

.d-factory-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.d-factory-logo {
  width: 88rpx; height: 88rpx;
  border-radius: 14rpx;
  background: var(--brand);
  color: #fff;
  font-weight: 700;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.d-factory-info { flex: 1; min-width: 0; }
.d-factory-name { font-size: 28rpx; font-weight: 700; color: var(--text); }
.d-factory-meta { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.d-factory-btn { height: 56rpx; padding: 0 24rpx; border-radius: 28rpx; font-size: 24rpx; }
.d-factory-tags {
  margin-top: 16rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.d-desc {
  font-size: 26rpx;
  color: var(--text-2);
  line-height: 1.65;
}
.d-desc-img {
  width: 100%;
  margin-top: 20rpx;
  border-radius: 8rpx;
}

.bar-placeholder { height: 140rpx; }

.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-top: 2rpx solid var(--divider);
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 10;
}
.bb-ic {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--text-2);
  padding: 0 10rpx;
}
.bb-ic-dot {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--brand-soft);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-bottom: 2rpx;
}
.bb-stepper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  justify-content: flex-end;
  margin-right: 8rpx;
}
.bb-step-label { font-size: 22rpx; color: var(--muted); }
.bb-action {
  border-radius: 36rpx;
  height: 72rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
}
