<view class="container od-container" wx:if="{{order}}">
  <!-- 状态条 -->
  <view class="od-status">
    <view class="od-status-title" style="color: {{order.statusColor}}">{{order.statusText}}</view>
    <view class="od-status-sub">
      <text wx:if="{{order.isPendingPay}}">请尽快完成支付</text>
      <text wx:elif="{{order.isPaid}}">商家正在备货</text>
      <text wx:elif="{{order.isShipped}}">{{order.shippingCompany || '已发货'}}{{order.shippingNo ? ' · ' + order.shippingNo : ''}}</text>
      <text wx:elif="{{order.isCompleted}}">交易已完成</text>
      <text wx:elif="{{order.isCancelled}}">订单已取消</text>
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="od-address card">
    <view class="od-addr-main">
      <text class="od-addr-name">{{order.address.contact}}</text>
      <text class="od-addr-phone">{{order.address.phone}}</text>
      <text wx:if="{{order.canEditAddress}}" class="od-addr-edit" bindtap="changeAddress">修改</text>
    </view>
    <view class="od-addr-line">
      {{order.address.province}}{{order.address.city}}{{order.address.district || ''}} {{order.address.detail}}
    </view>
  </view>

  <!-- 物流信息 -->
  <view class="od-logistics card" wx:if="{{order.shippingNo}}">
    <view class="od-card-title">物流信息</view>
    <view class="od-meta-row">
      <text class="od-meta-label">物流公司</text>
      <text class="od-meta-value">{{order.shippingCompany || order.shippingCompanyCode || '暂未填写'}}</text>
    </view>
    <view class="od-meta-row">
      <text class="od-meta-label">物流单号</text>
      <view class="od-meta-value-wrap">
        <text class="od-meta-value">{{order.shippingNo}}</text>
        <text class="od-copy" bindtap="copyShippingNo">复制</text>
      </view>
    </view>
    <view class="od-meta-row" wx:if="{{order.shippedAtText}}">
      <text class="od-meta-label">发货时间</text>
      <text class="od-meta-value">{{order.shippedAtText}}</text>
    </view>
    <view class="od-logistics-action" bindtap="viewLogistics">查看物流轨迹</view>
  </view>

  <!-- 商品 -->
  <view class="od-goods card">
    <view wx:for="{{order.items}}" wx:key="id" class="od-goods-item">
      <image src="{{item.image}}" class="od-goods-img" mode="aspectFill" wx:if="{{item.image}}" />
      <view class="od-goods-img cart-img-empty" wx:else>暂无图</view>
      <view class="od-goods-body">
        <view class="od-goods-name ellipsis-2">{{item.name}}</view>
        <view class="od-goods-spec" wx:if="{{item.spec}}">{{item.spec}}</view>
        <view class="od-goods-meta">¥{{item.priceText}} × {{item.qty}}</view>
      </view>
      <view class="od-goods-total">¥{{item.lineTotalText}}</view>
    </view>

    <view class="od-amount-row">
      <text>商品金额</text>
      <text>¥{{order.goodsAmountText}}</text>
    </view>
    <view class="od-amount-row" wx:if="{{order.shippingFee}}">
      <text>运费</text>
      <text>¥{{order.shippingFeeText}}</text>
    </view>
    <view class="od-amount-row" wx:else>
      <text>运费</text>
      <text class="od-ship-free">包邮</text>
    </view>
    <view class="od-amount-row od-amount-row-final">
      <text>实付金额</text>
      <text class="od-total">¥{{order.totalAmountText}}</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="od-meta card">
    <view class="od-meta-row">
      <text class="od-meta-label">订单编号</text>
      <view class="od-meta-value-wrap">
        <text class="od-meta-value">{{order.orderNo || order.id}}</text>
        <text class="od-copy" bindtap="copyOrderNo">复制</text>
      </view>
    </view>
    <view class="od-meta-row">
      <text class="od-meta-label">下单时间</text>
      <text class="od-meta-value">{{order.createdAtText}}</text>
    </view>
    <view class="od-meta-row" wx:if="{{order.paidAtText}}">
      <text class="od-meta-label">支付时间</text>
      <text class="od-meta-value">{{order.paidAtText}}</text>
    </view>
    <view class="od-meta-row" wx:if="{{order.remark}}">
      <text class="od-meta-label">订单备注</text>
      <text class="od-meta-value">{{order.remark}}</text>
    </view>
  </view>

  <view class="bar-placeholder"></view>

  <!-- 底部栏 -->
  <view class="bottom-bar">
    <view class="btn btn-outline bb-btn" bindtap="callService">联系客服</view>
    <view wx:if="{{order.shippingNo}}" class="btn btn-outline bb-btn" bindtap="viewLogistics">查看物流</view>
    <view wx:if="{{order.isPendingPay}}" class="btn btn-outline bb-btn" bindtap="cancelOrder">取消订单</view>
    <view wx:if="{{order.isPendingPay}}" class="btn btn-danger bb-btn" bindtap="payNow">立即付款</view>
    <view wx:if="{{order.isShipped}}" class="btn btn-primary bb-btn" bindtap="confirmReceive">确认收货</view>
  </view>
  <!-- 物流轨迹弹层 -->
  <view class="logistics-mask" wx:if="{{logisticsVisible}}" bindtap="closeLogistics">
    <view class="logistics-panel" catchtap="noop">
      <view class="logistics-head">
        <view>
          <view class="logistics-title">物流轨迹</view>
          <view class="logistics-sub">{{order.shippingCompany || order.shippingCompanyCode || ''}} {{order.shippingNo}}</view>
        </view>
        <view class="logistics-close" bindtap="closeLogistics">×</view>
      </view>

      <view wx:if="{{logisticsLoading}}" class="logistics-empty">查询中…</view>
      <view wx:elif="{{logisticsMessage}}" class="logistics-empty">{{logisticsMessage}}</view>
      <scroll-view wx:else scroll-y="true" class="logistics-list">
        <view wx:for="{{logisticsTraces}}" wx:key="time" class="trace-item {{index === 0 ? 'active' : ''}}">
          <view class="trace-dot"></view>
          <view class="trace-content">
            <view class="trace-text">{{item.text}}</view>
            <view class="trace-time">{{item.time}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<view wx:elif="{{loading}}" class="empty"><text class="empty-sub">加载中…</text></view>
