.s-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--divider);
}
.s-input-wrap {
  flex: 1;
  height: 64rpx;
  background: #f3f3f5;
  border-radius: 32rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.s-ic { color: var(--brand); font-size: 22rpx; }
.s-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text);
}
.s-clear {
  color: var(--muted);
  font-size: 28rpx;
  padding: 0 8rpx;
}
.s-cancel {
  color: var(--brand);
  font-size: 28rpx;
}

.s-section {
  background: #fff;
  margin-top: 16rpx;
  padding: 24rpx;
}
.s-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.s-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.s-clear-history {
  font-size: 22rpx;
  color: var(--muted);
}
.s-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.s-tag {
  padding: 10rpx 20rpx;
  background: #f5f5f7;
  font-size: 24rpx;
  color: var(--text-2);
  border-radius: 28rpx;
}
.s-tag-hot {
  background: var(--brand-soft);
  color: var(--brand);
}
.s-empty-mini {
  font-size: 24rpx;
  color: var(--muted);
}

.s-result-head {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: var(--muted);
  background: var(--bg);
}
.s-result-list { background: #fff; }
.empty { padding: 120rpx 0; text-align: center; }
.empty-title { font-size: 30rpx; color: var(--text); }
.empty-sub { font-size: 24rpx; color: var(--muted); margin-top: 8rpx; }
