<view class="container">
  <!-- 搜索栏 -->
  <view class="s-bar">
    <view class="s-input-wrap">
      <text class="s-ic">搜</text>
      <input
        class="s-input"
        placeholder="搜索陶瓷品名 / 货号 / 厂家"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="doSearch"
        confirm-type="search"
        focus="{{!categoryId}}"
      />
      <text wx:if="{{keyword}}" class="s-clear" bindtap="clearInput">×</text>
    </view>
    <view class="s-cancel" bindtap="cancel">取消</view>
  </view>

  <!-- 搜索前 -->
  <block wx:if="{{!searched}}">
    <view class="s-section">
      <view class="s-section-head">
        <text class="s-section-title">历史搜索</text>
        <text wx:if="{{history.length}}" class="s-clear-history" bindtap="clearHistory">清空</text>
      </view>
      <view class="s-tags">
        <view wx:for="{{history}}" wx:key="*this" class="s-tag" data-kw="{{item}}" bindtap="onTagTap">{{item}}</view>
        <view wx:if="{{!history.length}}" class="s-empty-mini">暂无历史</view>
      </view>
    </view>

    <view class="s-section" wx:if="{{hotKeywords.length}}">
      <view class="s-section-head">
        <text class="s-section-title">热门搜索</text>
      </view>
      <view class="s-tags">
        <view wx:for="{{hotKeywords}}" wx:key="*this" class="s-tag s-tag-hot" data-kw="{{item}}" bindtap="onTagTap">
          {{item}}
        </view>
      </view>
    </view>
  </block>

  <!-- 搜索结果 -->
  <block wx:else>
    <view class="s-result-head" wx:if="{{!loading || list.length}}">
      <text>共 {{list.length}} 件相关商品</text>
    </view>
    <view class="s-result-list">
      <block wx:for="{{list}}" wx:key="id">
        <product-card product="{{item}}" />
      </block>
      <view wx:if="{{!loading && list.length === 0}}" class="empty">
        <view class="empty-title">无匹配商品</view>
        <view class="empty-sub">试试其他关键词，或联系客服报价</view>
      </view>
      <view wx:if="{{loading}}" class="list-end">加载中…</view>
      <view wx:elif="{{!hasMore && list.length > 0}}" class="list-end">— 没有更多了 —</view>
    </view>
  </block>
</view>
