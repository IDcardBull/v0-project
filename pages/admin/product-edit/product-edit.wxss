page { background: #1f2a36; }
.page { min-height: 100vh; padding-bottom: 80rpx; color: #f0f4f8; }

.head {
  margin: 24rpx 32rpx 0;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.12);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex; gap: 20rpx;
}
.cover {
  width: 160rpx; height: 160rpx; border-radius: 8rpx; flex-shrink: 0;
  background: rgba(180, 200, 220, 0.08);
}
.meta { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.name {
  font-size: 28rpx; color: #f0f4f8;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx; border-radius: 4rpx;
  background: rgba(180, 200, 220, 0.1);
  color: rgba(240, 244, 248, 0.55);
}
.tag--on { background: rgba(180, 200, 220, 0.18); color: #b4c8dc; }
.tag--off { background: rgba(232, 156, 142, 0.12); color: #e89c8e; }
.head-ops { margin-top: 8rpx; display: flex; gap: 12rpx; }
.hop {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(180, 200, 220, 0.3);
  border-radius: 6rpx;
  color: rgba(240, 244, 248, 0.75);
}

.block { margin: 32rpx 32rpx 0; }
.block-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 8rpx 16rpx;
}
.block-head text { font-size: 24rpx; letter-spacing: 6rpx; color: rgba(240, 244, 248, 0.5); }
.scan-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: rgba(180, 200, 220, 0.14);
  color: #b4c8dc;
  border-radius: 6rpx;
  letter-spacing: 2rpx;
}

.sku-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.12);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}
.sku-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.sku-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.sku-spec { font-size: 26rpx; color: #f0f4f8; letter-spacing: 1rpx; }
.sku-code { font-size: 20rpx; color: rgba(240, 244, 248, 0.4); }
.sku-price { font-size: 26rpx; color: rgba(240, 244, 248, 0.7); }
.sku-price .unit { font-size: 20rpx; margin-right: 4rpx; }

.stepper {
  margin-top: 20rpx;
  display: flex; align-items: center; gap: 8rpx;
}
.step {
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  background: rgba(180, 200, 220, 0.14);
  color: #b4c8dc;
  border-radius: 8rpx; font-size: 36rpx;
}
.step-input {
  flex: 1; height: 64rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.16);
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx; color: #f0f4f8;
}
.step-save {
  height: 64rpx;
  padding: 0 24rpx;
  background: #6e92b6;
  color: #fff;
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; letter-spacing: 4rpx;
}
.step-save--loading { opacity: 0.6; }
.sku-tip { display: block; margin-top: 8rpx; font-size: 22rpx; color: rgba(240, 244, 248, 0.4); }

.empty {
  margin: 80rpx auto;
  text-align: center;
  color: rgba(240, 244, 248, 0.4);
  font-size: 26rpx;
}
