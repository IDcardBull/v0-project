<view class="page">
  <view class="search">
    <view class="search-input">
      <text class="search-icon">⌕</text>
      <input
        value="{{keyword}}"
        bindinput="onKeyword"
        bindconfirm="onSearch"
        confirm-type="search"
        placeholder="搜单号"
        placeholder-class="ph"
      />
    </view>
  </view>

  <scroll-view scroll-x class="tabs">
    <view class="tabs-inner">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab {{status === item.key ? 'tab--on' : ''}}"
        data-status="{{item.key}}"
        bindtap="switchTab"
      >
        <text>{{item.label}}</text>
        <text wx:if="{{counts[item.key || 'all']}}" class="badge">{{counts[item.key || 'all']}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading && list.length === 0}}" class="empty">载入中…</view>

  <view wx:elif="{{empty}}" class="empty">
    <view class="seal">空</view>
    <text class="empty-cn">暂无订单</text>
  </view>

  <view
    wx:for="{{list}}"
    wx:key="id"
    class="card"
    data-id="{{item.id}}"
    bindtap="goDetail"
  >
    <view class="card-head">
      <view class="head-left">
        <text class="order-no">单号 {{item.orderNo}}</text>
        <text wx:if="{{item.user.nickname || item.user.phone}}" class="user">{{item.user.nickname || item.user.phone}}</text>
      </view>
      <text class="status status-{{item.statusKey}}">{{item.statusLabel}}</text>
    </view>

    <view class="goods-list">
      <view wx:for="{{item.items}}" wx:for-item="goods" wx:key="id" class="goods-row">
        <image class="goods-img" src="{{goods.image}}" mode="aspectFill"></image>
        <view class="goods-meta">
          <text class="goods-name">{{goods.name}}</text>
          <text wx:if="{{goods.spec}}" class="goods-spec">{{goods.spec}}</text>
          <view class="goods-bottom">
            <text class="goods-price"><text class="unit">¥</text>{{goods.price}}</text>
            <text class="goods-qty">× {{goods.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card-foot">
      <text class="foot-qty">共 {{item.totalQty}} 件</text>
      <view class="foot-amount">
        总价
        <text class="big"><text class="unit">¥</text>{{item.total}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="more">载入中…</view>
  <view wx:elif="{{finished && list.length > 0}}" class="more">— 到底了 —</view>
  <view style="height: 160rpx;"></view>
</view>
