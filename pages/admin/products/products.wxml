<view class="page">
  <view class="search">
    <view class="search-input">
      <text class="search-icon">⌕</text>
      <input
        value="{{keyword}}"
        bindinput="onKeyword"
        bindconfirm="onSearch"
        confirm-type="search"
        placeholder="搜商品名 / 编号"
        placeholder-class="ph"
      />
      <view class="search-scan" catchtap="scanSearch">扫</view>
    </view>
  </view>

  <view wx:if="{{loading && list.length === 0}}" class="empty">载入中…</view>
  <view wx:elif="{{empty}}" class="empty">
    <view class="seal">空</view>
    <text class="empty-cn">暂无商品</text>
  </view>

  <view
    wx:for="{{list}}"
    wx:key="id"
    class="card"
    data-id="{{item.id}}"
    bindtap="goEdit"
  >
    <image class="cover" src="{{item.cover}}" mode="aspectFill"></image>
    <view class="meta">
      <text class="name">{{item.name}}</text>
      <text wx:if="{{item.code}}" class="code">编号 · {{item.code}}</text>
      <view class="row">
        <text class="price"><text class="unit">¥</text>{{item.minPrice}}<text wx:if="{{item.maxPrice !== item.minPrice}}"> - {{item.maxPrice}}</text></text>
        <text class="stock {{item.stock === 0 ? 'stock--zero' : ''}}">库存 {{item.stock}}</text>
      </view>
      <view class="tags">
        <text class="tag tag--{{item.status === 1 ? 'on' : 'off'}}">{{item.status === 1 ? '已上架' : '已下架'}}</text>
        <text class="tag tag--{{item.wholesaleEnabled ? 'on' : 'off'}}">批发{{item.wholesaleEnabled ? '可见' : '隐藏'}}</text>
        <text class="tag">SKU × {{item.skuCount}}</text>
      </view>
    </view>
    <view class="ops" catchtap="catchTap">
      <view class="op" data-id="{{item.id}}" catchtap="toggleListing">{{item.status === 1 ? '下架' : '上架'}}</view>
      <view class="op" data-id="{{item.id}}" catchtap="toggleWholesale">{{item.wholesaleEnabled ? '隐藏批发' : '开放批发'}}</view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="more">载入中…</view>
  <view wx:elif="{{finished && list.length > 0}}" class="more">— 到底了 —</view>
  <view style="height: 120rpx;"></view>
</view>
