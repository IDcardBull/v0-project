<view class="page">
  <view class="hero">
    <view class="brand">央</view>
    <text class="title">主理人入席</text>
    <text class="sub">凭账号密码进入批发管理工作台</text>
  </view>

  <view class="card">
    <view class="field">
      <text class="label">账号</text>
      <input
        class="input"
        value="{{username}}"
        bindinput="onUsername"
        placeholder="后台账号"
        placeholder-class="ph"
        confirm-type="next"
        adjust-position
      />
    </view>
    <view class="field">
      <text class="label">密码</text>
      <input
        class="input"
        value="{{password}}"
        bindinput="onPassword"
        password
        placeholder="6 位以上"
        placeholder-class="ph"
        confirm-type="done"
        bindconfirm="submit"
        adjust-position
      />
    </view>

    <view wx:if="{{error}}" class="error">{{error}}</view>

    <view class="submit {{loading ? 'submit--loading' : ''}}" bindtap="submit">
      <text>{{loading ? '验证中…' : '进入工作台'}}</text>
    </view>

    <text class="tip">仅限授权员工使用</text>
  </view>
</view>
