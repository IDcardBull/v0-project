page { background: #1f2a36; }
.page { min-height: 100vh; padding-bottom: 80rpx; color: #f0f4f8; }

.hero {
  padding: 56rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.hero-row { display: flex; align-items: center; justify-content: space-between; }
.hero-text { display: flex; flex-direction: column; gap: 4rpx; }
.hero-greet { font-size: 24rpx; letter-spacing: 8rpx; color: rgba(240, 244, 248, 0.45); }
.hero-name { font-size: 56rpx; letter-spacing: 4rpx; color: #f0f4f8; font-family: serif; }
.hero-out {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(240, 244, 248, 0.55);
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(180, 200, 220, 0.25);
  border-radius: 6rpx;
}
.hero-sub { font-size: 24rpx; letter-spacing: 2rpx; color: rgba(180, 200, 220, 0.6); }

.kpi-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}
.kpi-primary {
  flex: 1.3;
  background: linear-gradient(160deg, #b4c8dc 0%, #6e92b6 100%);
  color: #1f2a36;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-height: 220rpx;
  justify-content: space-between;
}
.k-label { font-size: 22rpx; letter-spacing: 6rpx; color: rgba(31, 42, 54, 0.65); }
.k-value { font-size: 88rpx; line-height: 1; color: #1f2a36; font-weight: 500; }
.k-action { font-size: 22rpx; letter-spacing: 4rpx; color: rgba(31, 42, 54, 0.7); }

.kpi-col { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }
.kpi-mini {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex; flex-direction: column; justify-content: center; gap: 8rpx;
}
.km-label { font-size: 22rpx; letter-spacing: 4rpx; color: rgba(240, 244, 248, 0.5); }
.km-value { font-size: 44rpx; color: #f0f4f8; }
.km-value .unit { font-size: 22rpx; margin-right: 4rpx; color: rgba(240, 244, 248, 0.55); }

.block { padding: 48rpx 32rpx 0; }
.block-head { display: flex; align-items: baseline; gap: 16rpx; padding: 0 8rpx 20rpx; }
.head-cn { font-size: 28rpx; letter-spacing: 6rpx; color: #f0f4f8; }
.head-en { font-size: 18rpx; letter-spacing: 6rpx; color: rgba(240, 244, 248, 0.4); }

.status-grid {
  display: flex;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.14);
  border-radius: 16rpx;
  overflow: hidden;
}
.status-cell {
  flex: 1;
  padding: 32rpx 0;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  border-right: 1rpx solid rgba(180, 200, 220, 0.08);
}
.status-cell:last-child { border-right: none; }
.snum { font-size: 44rpx; color: #b4c8dc; }
.slabel { font-size: 22rpx; letter-spacing: 2rpx; color: rgba(240, 244, 248, 0.55); }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.g-item {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.14);
  border-radius: 16rpx;
  padding: 32rpx 0;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.g-item.warn {
  background: rgba(232, 156, 142, 0.08);
  border-color: rgba(232, 156, 142, 0.3);
}
.gnum { font-size: 44rpx; color: #f0f4f8; }
.g-item.warn .gnum { color: #e89c8e; }
.glabel { font-size: 22rpx; letter-spacing: 2rpx; color: rgba(240, 244, 248, 0.55); }

.actions { padding: 48rpx 32rpx 0; display: flex; flex-direction: column; gap: 12rpx; }
.action {
  display: flex; align-items: center; gap: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(180, 200, 220, 0.12);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}
.a-glyph {
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  background: rgba(180, 200, 220, 0.14);
  color: #b4c8dc;
  border-radius: 8rpx; font-size: 28rpx;
}
.a-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.a-cn { font-size: 28rpx; color: #f0f4f8; letter-spacing: 2rpx; }
.a-en { font-size: 20rpx; letter-spacing: 6rpx; color: rgba(240, 244, 248, 0.45); }
.a-arrow { font-size: 36rpx; color: rgba(240, 244, 248, 0.5); }
