/**app.wxss**/
page {
  --brand: #3c5a6f;
  --brand-soft: #eef3f5;
  --brand-light: #f7fafb;
  --price: #c0392b;
  --price-soft: #fdecea;
  --bg: #f5f5f7;
  --surface: #ffffff;
  --text: #222222;
  --text-2: #555555;
  --muted: #999999;
  --divider: #ededed;

  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC",
    "Helvetica Neue", "Microsoft YaHei", sans-serif;
  line-height: 1.5;
}

view, text, button, input, textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  line-height: 1.4;
}
button::after { border: none; }

.container {
  width: 100%;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用文字样式 */
.text-muted { color: var(--muted); }
.text-brand { color: var(--brand); }
.text-price { color: var(--price); font-weight: 600; }
.ellipsis-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 通用徽章 / 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 0 10rpx;
  height: 32rpx;
  font-size: 20rpx;
  border-radius: 6rpx;
  color: var(--brand);
  background: var(--brand-soft);
  margin-right: 8rpx;
}
.tag-danger {
  color: var(--price);
  background: var(--price-soft);
}

/* 通用按钮 */
.btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: opacity .15s;
}
.btn-primary {
  background: var(--brand);
  color: #fff;
}
.btn-primary:active { opacity: .85; }
.btn-outline {
  background: #fff;
  color: var(--brand);
  border: 2rpx solid var(--brand);
}
.btn-danger {
  background: var(--price);
  color: #fff;
}

/* 卡片 */
.card {
  background: var(--surface);
  border-radius: 16rpx;
  overflow: hidden;
}

/* 分割线 */
.hr {
  height: 2rpx;
  background: var(--divider);
}
