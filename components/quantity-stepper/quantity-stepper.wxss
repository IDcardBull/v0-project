.qs {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  border: 2rpx solid var(--brand);
  border-radius: 28rpx;
  overflow: hidden;
  background: #fff;
}
.qs-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  font-size: 32rpx;
  user-select: none;
}
.qs-btn:active { background: var(--brand-soft); }
.qs-input {
  width: 80rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text);
  font-weight: 600;
  background: #fff;
  border-left: 2rpx solid var(--brand-soft);
  border-right: 2rpx solid var(--brand-soft);
  padding: 0;
  min-height: 0;
}
