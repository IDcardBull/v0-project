.pc {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
  border-bottom: 2rpx solid var(--divider);
}

.pc-img {
  position: relative;
  width: 224rpx;
  height: 224rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.pc-cover { width: 100%; height: 100%; display: block; }

.pc-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  height: 32rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(60, 90, 111, 0.92);
  border-radius: 4rpx;
  display: flex;
  align-items: center;
}
.badge-danger { background: rgba(192, 57, 43, 0.92); }
.badge-warn { background: rgba(201, 138, 46, 0.92); }

.pc-sold {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(to top, rgba(0,0,0,.55), rgba(0,0,0,0));
}

.pc-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pc-title {
  font-size: 28rpx;
  line-height: 1.35;
  color: var(--text);
  font-weight: 600;
  word-break: break-all;
}

.pc-attrs { display: flex; flex-wrap: wrap; gap: 4rpx; }

.pc-sku {
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 0.5rpx;
}

.pc-moq {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background: var(--brand-soft);
  border-radius: 6rpx;
  align-self: flex-start;
  margin-top: 2rpx;
}
.pc-moq-label {
  font-size: 20rpx;
  color: var(--brand);
  opacity: .75;
}
.pc-moq-value {
  font-size: 22rpx;
  color: var(--brand);
  font-weight: 600;
}

.pc-tiers {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rpx 20rpx;
  margin-top: 4rpx;
}
.pc-tier {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 20rpx;
  border-bottom: 2rpx dashed #f0f0f0;
  padding: 2rpx 0;
}
.pc-tier-range { color: var(--muted); }
.pc-tier-price { color: var(--price); font-weight: 600; }

.pc-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.pc-price-wrap {
  display: flex;
  align-items: baseline;
  color: var(--price);
}
.pc-price-currency { font-size: 22rpx; font-weight: 600; }
.pc-price { font-size: 36rpx; font-weight: 700; line-height: 1; }
.pc-unit { font-size: 20rpx; color: var(--muted); margin-left: 4rpx; }

.pc-btn {
  height: 56rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  background: var(--brand);
  color: #fff;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pc-btn:active { opacity: .85; }
