.pc {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
  border-bottom: 2rpx solid var(--divider);
}

.pc-img {
  position: relative;
  width: 224rpx;
  height: 224rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}
.pc-cover { width: 100%; height: 100%; display: block; }
.pc-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 22rpx;
  background: #f5f5f5;
}

.pc-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  height: 32rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(60, 90, 111, 0.92);
  border-radius: 4rpx;
  display: flex;
  align-items: center;
}

.pc-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pc-title {
  font-size: 28rpx;
  line-height: 1.35;
  color: var(--text);
  font-weight: 600;
  word-break: break-all;
}

.pc-brand {
  font-size: 22rpx;
  color: var(--muted);
}

.pc-tags { display: flex; flex-wrap: wrap; gap: 6rpx; }
.tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  background: #f3f4f5;
  color: var(--muted);
  border-radius: 4rpx;
}

.pc-moq {
  display: inline-flex;
  align-self: flex-start;
  align-items: center;
  padding: 4rpx 12rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 6rpx;
}

.pc-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 6rpx;
}

.pc-price-wrap {
  display: flex;
  align-items: baseline;
  color: var(--price);
}
.pc-price-currency { font-size: 22rpx; font-weight: 600; }
.pc-price { font-size: 36rpx; font-weight: 700; line-height: 1; }
.pc-unit { font-size: 20rpx; color: var(--muted); margin-left: 4rpx; }

.pc-sales {
  font-size: 22rpx;
  color: var(--muted);
}
